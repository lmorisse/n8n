@model WebApp.Models.User

<form method="post">
    <div>
        <label>Email:</label>
        <input asp-for="Email" />
        <span asp-validation-for="Email"></span>
    </div>
    <div>
        <label>Password:</label>
        <input asp-for="PasswordHash" type="password" />
    </div>
    <button type="submit">Register</button>
</form>
